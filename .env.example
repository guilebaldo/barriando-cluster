# =============================================
# 📌 Configuración General
# =============================================

NEXT_PUBLIC_APP_URL="https://barriando.org"
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =============================================
# 🔐 Auth.js (NextAuth v5)
# =============================================

# AUTH_SECRET y AUTH_URL son obligatorios en producción.
# trustHost está forzado en src/auth.ts; AUTH_TRUST_HOST sigue siendo útil como respaldo.
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="https://barriando.org"
AUTH_TRUST_HOST=true
# Opcional: alias para compatibilidad con el cliente de next-auth/react
NEXTAUTH_URL="https://barriando.org"

# =============================================
# 🔑 Google OAuth
# =============================================

GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# =============================================
# ✉️ Resend (Magic Links)
# =============================================

RESEND_API_KEY="re_xxxxxxxx"

# =============================================
# 💳 Stripe
# =============================================

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Suscripción (tarjeta / domiciliación) — Price IDs recurrentes
STRIPE_PRICE_ID=""
STRIPE_PRICE_ID_VECINO=""
STRIPE_PRICE_ID_NEGOCIO_FAMILIAR=""
STRIPE_PRICE_ID_MEDIANA_EMPRESA=""
STRIPE_PRICE_ID_GRAN_EMPRESA=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# OXXO usa price_data (montos de PLAN_PRICES_MXN). Activa OXXO en
# Dashboard → Settings → Payment methods (Live).
# Webhook Live debe incluir además:
#   checkout.session.async_payment_succeeded
#   checkout.session.async_payment_failed (opcional)
# SPEI / bank transfer: pausado hasta verificación de cuenta Stripe.

# =============================================
# 🗺️ Google Maps & Places
# =============================================

NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# =============================================
# 🏦 Pagos manuales (transferencia / efectivo)
# =============================================

BARRIANDO_CLABE="646180157000000004"
BARRIANDO_PAYMENT_EMAIL="hola@barriandopuebla.com"
BARRIANDO_BANK_LABEL="STP — Asociación Barriando"

# =============================================
# 🗄️ Base de datos
# =============================================

DATABASE_URL="postgresql://user:password@host/database?sslmode=require"