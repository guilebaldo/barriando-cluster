# =============================================
# 📌 Configuración General
# =============================================

NEXT_PUBLIC_APP_URL="https://barriandopuebla.com"
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =============================================
# 🔐 Auth.js (NextAuth v5)
# =============================================

# AUTH_SECRET y AUTH_URL son obligatorios en producción.
# trustHost está forzado en src/auth.ts; AUTH_TRUST_HOST sigue siendo útil como respaldo.
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="https://barriandopuebla.com"
AUTH_TRUST_HOST=true
# Opcional: alias para compatibilidad con el cliente de next-auth/react
NEXTAUTH_URL="https://barriandopuebla.com"

# =============================================
# 🔑 Google OAuth
# =============================================

GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# =============================================
# ✉️ Resend (Magic Links)
# =============================================

RESEND_API_KEY="re_xxxxxxxx"

# =============================================
# 💳 Stripe
# =============================================

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""
STRIPE_PRICE_ID_NEGOCIO_FAMILIAR=""
STRIPE_PRICE_ID_MEDIANA_EMPRESA=""
STRIPE_PRICE_ID_GRAN_EMPRESA=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# =============================================
# 🗄️ Base de datos
# =============================================

DATABASE_URL="postgresql://user:password@host/database?sslmode=require"